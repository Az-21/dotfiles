# PATH
export PATH="$HOME/.local/bin:$PATH"

# Environment
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat --plain"
export MANPAGER="sh -c 'col -bx | bat -l man --plain'"

# Modern tooling
alias cat="bat"
alias cd="z"
alias find="fd"
alias grep="rg"
alias vi="nvim"
alias vim="nvim"
alias filehash="sha256sum"
pip() { uv pip "$@" }
venv() { uv venv "$@" }

# eza (ls/tree replacements)
alias la="eza --icons --group-directories-first -la --header --git"
alias ll="eza --icons --group-directories-first -l --header --git"
alias ls="eza --icons --group-directories-first"
alias lt="eza --icons --tree --level=2 --group-directories-first"
alias lta="eza --icons --tree --level=2 -a --group-directories-first"
alias tree="eza --icons --tree --group-directories-first"

# yazi — open file manager in current dir, and cd into last visited dir on exit
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    z "$cwd"
  fi
  rm -f -- "$tmp"
}

# fzf terminal history
export FZF_CTRL_R_OPTS="--height 100% --no-cycle"
source <(fzf --zsh) 2>/dev/null
bindkey '^[OA' fzf-history-widget
bindkey '^[[A' fzf-history-widget

# Plugins
if [[ "$OSTYPE" == "darwin"* ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"

    if [ -f "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
        source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    fi

    if [ -f "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
        source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
    fi
fi

# Initialzie tools
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
eval "$(fnm env --use-on-cd)"
eval "$(fzf --zsh)"
