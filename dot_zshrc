# PATH
export PATH="$HOME/.local/bin:$PATH"

# Environment
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat --plain"
export MANPAGER="sh -c 'col -bx | bat -l man --plain'"

# Completion
autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt APPEND_HISTORY        # Append instead of overwrite on exit
setopt INC_APPEND_HISTORY    # Write to file immediately, not just on exit
setopt SHARE_HISTORY         # Share history across all open sessions
setopt HIST_IGNORE_DUPS      # Don't record consecutive duplicates
setopt HIST_IGNORE_SPACE     # Don't record commands prefixed with a space
setopt HIST_REDUCE_BLANKS    # Strip superfluous whitespace

# Modern tooling
alias cat="bat"
alias cd="z"
alias find="fd"
alias grep="rg"
alias vi="nvim"
alias vim="nvim"
alias filehash="sha256sum"
pip() { uv pip "$@" }
venv() { uv venv "$@" }

# eza (ls/tree replacements)
alias la="eza --icons --group-directories-first -la --header --git"
alias ll="eza --icons --group-directories-first -l --header --git"
alias ls="eza --icons --group-directories-first"
alias lt="eza --icons --tree --level=2 --group-directories-first"
alias lta="eza --icons --tree --level=2 -a --group-directories-first"
alias tree="eza --icons --tree --group-directories-first"

# GitHub Desktop Plus
# Start from the repo folder for poorly configured git hooks
alias ghplus="nohup github-desktop-plus > /dev/null 2>&1 & disown"

# Arch extra/zed installs zed as zeditor
alias zed="zeditor"

# yazi — open file manager in current dir, and cd into last visited dir on exit
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"

  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    z "$cwd"
  fi

  rm -f -- "$tmp"
}

# Terminal history
function tv-history-up() {
    local selected
    if [[ -n "$BUFFER" ]]; then
        selected=$(fc -rnl 1 | awk '!seen[$0]++' | rg -iF "$BUFFER" | tv --input-position bottom --no-preview)
    else
        selected=$(fc -rnl 1 | awk '!seen[$0]++' | tv --input-position bottom --no-preview)
    fi
    if [[ -n "$selected" ]]; then
        BUFFER="$selected"
        CURSOR=${#BUFFER}
    fi
    zle reset-prompt
}
zle -N tv-history-up
bindkey '^[[A' tv-history-up
bindkey '^[OA' tv-history-up


# zsh Plugins
if [[ "$OSTYPE" == "darwin"* ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"

    if [ -f "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
        source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    fi

    if [ -f "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
        source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
    fi

elif [[ "$OSTYPE" == "linux-gnu"* ]]; then

    # Common Linux paths for zsh plugins (Arch + Debian + Manual)
    _ZSH_PLUGIN_DIRS=(
        /usr/share/zsh/plugins
        /usr/share/zsh-autosuggestions
        /usr/share/zsh-syntax-highlighting
        /usr/local/share/zsh/plugins
    )

    for _dir in "${_ZSH_PLUGIN_DIRS[@]}"; do
        if [ -f "$_dir/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
            source "$_dir/zsh-autosuggestions/zsh-autosuggestions.zsh"
            break
        elif [ -f "$_dir/zsh-autosuggestions.zsh" ]; then
            source "$_dir/zsh-autosuggestions.zsh"
            break
        fi
    done

    for _dir in "${_ZSH_PLUGIN_DIRS[@]}"; do
        if [ -f "$_dir/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
            source "$_dir/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
            break
        elif [ -f "$_dir/zsh-syntax-highlighting.zsh" ]; then
            source "$_dir/zsh-syntax-highlighting.zsh"
            break
        fi
    done

    unset _dir _ZSH_PLUGIN_DIRS
fi

# Initialzie tools
eval "$(mise activate zsh)"
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
