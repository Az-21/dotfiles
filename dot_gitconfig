[user]
    name = Abhishek Choudhary
    signingkey = ~/.ssh/id_ed25519_github_az21.pub

[gpg]
    format = ssh

[commit]
    gpgsign = true

[init]
    defaultBranch = main

[color]
    ui = auto

[push]
    default = simple

[fetch]
    prune = true

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
